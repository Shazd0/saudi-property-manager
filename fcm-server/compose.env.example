# Copy to "compose.env" in this folder (fcm-server/) and adjust. Docker Compose loads it with:
#   docker compose -f fcm-server/docker-compose.yml --env-file fcm-server/compose.env up -d
#
# Your Amlak web app URL(s) — where users open the SPA or Electron loads remote config; comma-separated, no spaces unless quoted.
# Example: the origin only (scheme + host + optional port, no path).
ZATCA_CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# Optional: if port 3002 on the host is already taken, map another host port:
# ZATCA_PORT=3003
