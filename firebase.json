{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log"]
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/owner.html",
        "destination": "/owner.html"
      },
      {
        "source": "/tenant.html",
        "destination": "/tenant.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
