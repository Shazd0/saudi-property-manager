{
  "name": "saudi-property-manager",
  "description": "Amlak property management desktop and web application",
  "author": "Amlak Team",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --force\" \"node fcm-server/zatca-service.js\"",
    "postinstall": "npm --prefix fcm-server install",
    "start": "node fcm-server/zatca-service.js",
    "zatca:server": "node fcm-server/zatca-service.js",
    "zatca:docker": "docker compose -f fcm-server/docker-compose.yml up -d --build",
    "zatca:docker:https": "docker compose -f fcm-server/docker-compose.https.yml up -d --build",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "desktop:dev": "electron .",
    "desktop:assets": "powershell -ExecutionPolicy Bypass -File ./tools/generate-installer-assets.ps1",
    "desktop:build": "npm run desktop:assets && npm run build && electron-builder --win nsis",
    "desktop:build:unsigned": "npm run desktop:assets && npm run build && electron-builder --win nsis --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "@google-cloud/storage": "^6.12.0",
    "firebase": "^12.7.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.555.0",
    "pdfjs-dist": "^5.4.530",
    "react": "^19.2.0",
    "react-csv": "^2.2.2",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.5.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^1.2.0"
  },
  "build": {
    "appId": "com.amlak.saudi-property-manager",
    "productName": "Amlak Property Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Amlak Property Manager",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp"
    }
  }
}
