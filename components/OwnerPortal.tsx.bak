import React, { useState, useEffect, useMemo } from 'react';
import { User, Building, Transaction, TransactionType, Contract, ExpenseCategory } from '../types';
import { getUsers, getTransactions, getBuildings, getContracts, setUserScope } from '../services/firestoreService';
import { Crown, Building2, TrendingUp, TrendingDown, DollarSign, Percent, Users, Wallet, Home, FileSignature, Sparkles } from 'lucide-react';

interface OwnerPortalProps {
  currentUser?: User;
}

/* ═══ DESIGN TOKENS ═══ */
const CHART_COLORS = ['#1e40af', '#22c55e', '#f59e0b', '#a855f7', '#ef4444', '#06b6d4', '#f97316', '#ec4899'];
const PRIMARY = '#1e40af';

/* ═══ UI ATOMS ═══ */
const Card = ({ children, className = '', style = {} }: { children: React.ReactNode; className?: string; style?: React.CSSProperties }) => (
  <div className={`bg-white rounded-2xl overflow-hidden ${className}`}
    style={{ boxShadow: '0 1px 3px rgba(0,0,0,0.04), 0 4px 16px rgba(0,0,0,0.03)', border: '1px solid rgba(0,0,0,0.04)', ...style }}>
    {children}
  </div>
);

const KpiCard = ({ label, value, sub, icon: Icon, accent, highlight }: any) => (
  <Card className={`p-3.5 sm:p-5 group hover:shadow-lg transition-shadow duration-300 ${highlight ? 'ring-1 ring-blue-100' : ''}`}
    style={highlight ? { background: 'linear-gradient(145deg, #eff6ff, #f8fafc)' } : {}}>
    <div className="flex items-start justify-between mb-2 sm:mb-3">
      <span className="text-[9px] sm:text-[10px] font-bold uppercase tracking-[1px] sm:tracking-[1.5px] text-slate-400 leading-tight pr-1">{label}</span>
      <div className="w-7 h-7 sm:w-8 sm:h-8 rounded-lg flex items-center justify-center flex-shrink-0" style={{ background: `${accent}12` }}>
        <Icon size={14} className="sm:hidden" style={{ color: accent }} />
        <Icon size={15} className="hidden sm:block" style={{ color: accent }} />
      </div>
    </div>
    <p className="text-base sm:text-[22px] font-black tracking-tight leading-tight" style={{ color: highlight ? PRIMARY : '#1e293b' }}>{value}</p>
    {sub && <p className="text-[9px] sm:text-[10px] mt-0.5 sm:mt-1 font-semibold text-slate-300">{sub}</p>}
  </Card>
);

const SectionTitle = ({ icon: Icon, title, accent = PRIMARY, right }: any) => (
  <div className="flex items-center justify-between mb-5">
    <div className="flex items-center gap-2.5">
      <div className="w-8 h-8 rounded-lg flex items-center justify-center" style={{ background: `${accent}10` }}>
        <Icon size={15} style={{ color: accent }} />
      </div>
      <h3 className="text-sm font-black text-slate-700 tracking-tight">{title}</h3>
    </div>
    {right}
  </div>
);

/* ═══ CHART TOOLTIP ═══ */
const ChartTooltip = ({ active, payload, label }: any) => {
  if (!active || !payload?.length) return null;
  return (
    <div className="bg-white rounded-xl p-3 text-xs shadow-xl border border-slate-100">
      <p className="font-bold text-slate-500 mb-1.5">{label}</p>
      {payload.map((p: any, i: number) => (
        <div key={i} className="flex items-center gap-2">
          <div className="w-2 h-2 rounded-full" style={{ background: p.color }} />
          <span className="text-slate-400">{p.name}:</span>
          <span className="font-bold text-slate-700">{fmt(p.value)} SAR</span>
        </div>
      ))}
    </div>
  );
};

const fmt = (n: number) => {
  if (n === 0) return '0';
  return n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
};
const OWNER_EXPENSE_CATEGORIES = [ExpenseCategory.OWNER_EXPENSE, 'Owner Profit Withdrawal'];

/* ═══════════════════════════════════════════════════════════════
   MAIN COMPONENT
═══════════════════════════════════════════════════════════════ */
const OwnerPortal: React.FC<OwnerPortalProps> = ({ currentUser }) => {
  const [owners, setOwners] = useState<User[]>([]);
  const [selectedOwnerId, setSelectedOwnerId] = useState<string>('');
  const [buildings, setBuildings] = useState<Building[]>([]);
  const [transactions, setTransactions] = useState<Transaction[]>([]);
  const [contracts, setContracts] = useState<Contract[]>([]);
  const [loading, setLoading] = useState(true);
  const [dateRange, setDateRange] = useState<'all' | 'year' | 'quarter' | 'month'>('year');

  useEffect(() => {
    const load = async () => {
      setLoading(true);
      try {
        setUserScope({ role: 'ADMIN', buildingIds: [] });
        const [usrs, blds, txs, ctrs] = await Promise.all([getUsers(), getBuildings(), getTransactions(), getContracts()]);
        const ownerList = (usrs || []).filter((u: User) => u.isOwner || u.role === 'OWNER' as any);
        setOwners(ownerList);
        setBuildings(blds || []);
        setTransactions(txs || []);
        setContracts(ctrs || []);
        if (ownerList.length > 0) {
          if (currentUser?.id) {
            const match = ownerList.find(o => o.id === currentUser.id);
            setSelectedOwnerId(match ? match.id : ownerList[0].id);
          } else if (!selectedOwnerId) {
            setSelectedOwnerId(ownerList[0].id);
          }
        }
      } catch (e) { console.error('OwnerPortal load error:', e); }
      setLoading(false);
    };
    load();
  }, []);

  const selectedOwner = useMemo(() => owners.find(o => o.id === selectedOwnerId), [owners, selectedOwnerId]);
  const sharePercent = (selectedOwner?.sharePercentage || 0) / 100;

  // In standalone mode (currentUser provided), the owner can only see their own data
  const isStandalone = !!currentUser;

  // Exclude opening balance transactions from all calculations
  const filteredTransactions = useMemo(() => {
    if (!transactions.length) return [];
    const now = new Date();
    let startDate: Date | null = null;
    if (dateRange === 'month') startDate = new Date(now.getFullYear(), now.getMonth(), 1);
    else if (dateRange === 'quarter') startDate = new Date(now.getFullYear(), Math.floor(now.getMonth() / 3) * 3, 1);
    else if (dateRange === 'year') startDate = new Date(now.getFullYear(), 0, 1);
    return transactions.filter(t => {
      // Exclude opening balance
      if (t.borrowingType === 'OPENING_BALANCE') return false;
      if (startDate && t.date) return new Date(t.date) >= startDate;
      return true;
    });
  }, [transactions, dateRange]);

  const ownerBuildingIds = selectedOwner?.ownerBuildingIds || selectedOwner?.buildingIds || [];
  const ownerBuildings = buildings.filter(b => ownerBuildingIds.includes(b.id));
  const ownerScopedTransactions = useMemo(() => {
    return filteredTransactions.filter(t => {
      const inOwnerBuilding = ownerBuildingIds.includes(t.buildingId || '');
      const isOwnerExpense = t.type === TransactionType.EXPENSE
        && OWNER_EXPENSE_CATEGORIES.includes((t.expenseCategory || '') as any)
        && !!selectedOwnerId
        && (t as any).ownerId === selectedOwnerId;
      return inOwnerBuilding || isOwnerExpense;
    });
  }, [filteredTransactions, ownerBuildingIds, selectedOwnerId]);

  const buildingFinancials = useMemo(() => {
    // Helper to identify ALL borrowing opening balance transactions (tracked separately)
    const isBorrowingOpeningBal = (t: Transaction) => t.borrowingType === 'OPENING_BALANCE' || (t as any).isOwnerOpeningBalance === true;
    return ownerBuildings.map(building => {
      const bTxs = filteredTransactions.filter(t => t.buildingId === building.id);
      const income = bTxs.filter(t => t.type === TransactionType.INCOME).reduce((s, t) => s + (Number(t.amount) || 0), 0);
      // Exclude all borrowing opening balance from building expense totals
      const expense = bTxs.filter(t => t.type === TransactionType.EXPENSE && !isBorrowingOpeningBal(t)).reduce((s, t) => s + (Number(t.amount) || 0), 0);
      const profit = income - expense;
      const activeContracts = contracts.filter(c => c.buildingId === building.id && c.status === 'Active');
      const totalUnits = building.units?.length || 0;
      const occupiedUnits = activeContracts.length;
      const occupancyRate = totalUnits > 0 ? (occupiedUnits / totalUnits) * 100 : 0;
      return { id: building.id, name: building.name, income, expense, profit, ownerShare: profit * sharePercent, totalUnits, occupiedUnits, occupancyRate, activeContracts: activeContracts.length, monthlyRent: activeContracts.reduce((s, c) => s + ((c.rentValue || 0) / 12), 0) };
    });
  }, [ownerBuildings, filteredTransactions, contracts, sharePercent]);

  const totals = useMemo(() => {
    const totalIncome = buildingFinancials.reduce((s, b) => s + b.income, 0);
    const totalExpense = buildingFinancials.reduce((s, b) => s + b.expense, 0);
    const totalProfit = totalIncome - totalExpense;
    const ownerProfit = totalProfit * sharePercent;
    const ownerExpenseTotal = ownerScopedTransactions
      .filter(t => t.type === TransactionType.EXPENSE && OWNER_EXPENSE_CATEGORIES.includes((t.expenseCategory || '') as any) && (t as any).ownerId === selectedOwnerId)
      .reduce((s, t) => s + (Number(t.amount) || 0), 0);
    const ownerProfitNet = ownerProfit - ownerExpenseTotal;
    const totalUnits = buildingFinancials.reduce((s, b) => s + b.totalUnits, 0);
    const occupiedUnits = buildingFinancials.reduce((s, b) => s + b.occupiedUnits, 0);
    const avgOccupancy = totalUnits > 0 ? (occupiedUnits / totalUnits) * 100 : 0;
    const profitMargin = totalIncome > 0 ? (totalProfit / totalIncome) * 100 : 0;
    const expectedMonthlyRent = buildingFinancials.reduce((s, b) => s + b.monthlyRent, 0);
    return { totalIncome, totalExpense, totalProfit, ownerProfit, ownerExpenseTotal, ownerProfitNet, totalUnits, occupiedUnits, avgOccupancy, profitMargin, expectedMonthlyRent };
  }, [buildingFinancials, sharePercent, ownerScopedTransactions, selectedOwnerId]);

  // Owner Opening Balance calculation (from previous system - not included in regular totals)
  const ownerOpeningBalanceData = useMemo(() => {
    // Find all opening balance transactions for the selected owner
    const openingBalanceTxs = transactions.filter(t => 
      ((t as any).isOwnerOpeningBalance === true || (t.borrowingType === 'OPENING_BALANCE' && (t as any).ownerId)) &&
      (t as any).ownerId === selectedOwnerId
    );
    const totalOpeningBalance = openingBalanceTxs.reduce((s, t) => s + (Number(t.amount) || 0), 0);
    // Outstanding = Opening Balance - Owner Expenses paid
    const outstanding = totalOpeningBalance - (totals?.ownerExpenseTotal || 0);
    return { totalOpeningBalance, outstanding, transactions: openingBalanceTxs };
  }, [transactions, selectedOwnerId, totals?.ownerExpenseTotal]);

  // Owner Opening Expense calculation (from previous system - opening expenses)
  const ownerOpeningExpenseData = useMemo(() => {
    // Find all opening expense transactions for the selected owner
    const openingExpenseTxs = transactions.filter(t => 
      (t.expenseCategory === 'Owner Opening Expense' || (t as any).isOwnerOpeningExpense === true) &&
      (t as any).ownerId === selectedOwnerId &&
      t.type === TransactionType.EXPENSE
    );
    const totalOpeningExpense = openingExpenseTxs.reduce((s, t) => s + (Number(t.amount) || 0), 0);
    return { totalOpeningExpense, transactions: openingExpenseTxs };
  }, [transactions, selectedOwnerId]);

  // All Owners Summary (admin only) - Opening Balance + Expenses for every owner
  const allOwnersSummary = useMemo(() => {
    return owners.map(owner => {
      const openingBalanceTxs = transactions.filter(t =>
        ((t as any).isOwnerOpeningBalance === true || (t.borrowingType === 'OPENING_BALANCE' && (t as any).ownerId)) &&
        (t as any).ownerId === owner.id
      );
      const openingBalance = openingBalanceTxs.reduce((s, t) => s + (Number(t.amount) || 0), 0);

      const expenseTxs = transactions.filter(t =>
        t.type === TransactionType.EXPENSE &&
        OWNER_EXPENSE_CATEGORIES.includes((t.expenseCategory || '') as any) &&
        (t as any).ownerId === owner.id
      );
      const expenses = expenseTxs.reduce((s, t) => s + (Number(t.amount) || 0), 0);

      // Full income/expense for this owner's buildings (all time)
      const ownerBldIds = owner.ownerBuildingIds || (owner as any).buildingIds || [];
      const ownerTxs = transactions.filter(t => ownerBldIds.includes(t.buildingId || ''));
      const totalIncome = ownerTxs.filter(t => t.type === TransactionType.INCOME).reduce((s, t) => s + (Number(t.amount) || 0), 0);
      const totalExpense = ownerTxs.filter(t => t.type === TransactionType.EXPENSE && t.borrowingType !== 'OPENING_BALANCE').reduce((s, t) => s + (Number(t.amount) || 0), 0);
      const netProfit = totalIncome - totalExpense;
      const ownerShare = netProfit * ((owner.sharePercentage || 0) / 100);

      return {
        id: owner.id,
        name: owner.name,
        sharePercentage: owner.sharePercentage || 0,
        openingBalance,
        expenses,
        combined: openingBalance + expenses,
        totalIncome,
        totalExpense,
        netProfit,
        ownerShare,
        ownerNetAfterExpense: ownerShare - expenses,
        openingBalanceTxs,
        expenseTxs,
      };
    }).filter(o => o.openingBalance > 0 || o.expenses > 0 || o.totalIncome > 0);
  }, [owners, transactions]);

  // Staff Borrowing Opening Balance calculation (for owner's buildings)
  const staffBorrowingOpeningBalance = useMemo(() => {
    const staffOpeningBalanceTxs = transactions.filter(t => 
      t.borrowingType === 'OPENING_BALANCE' && 
      !((t as any).isOwnerOpeningBalance === true) &&
      !((t as any).ownerId) &&
      ownerBuildingIds.includes(t.buildingId || '')
    );
    const totalStaffOpeningBalance = staffOpeningBalanceTxs.reduce((s, t) => s + (Number(t.amount) || 0), 0);
    // Get net borrowing (borrowed - repaid)
    const borrowingTxs = transactions.filter(t => ownerBuildingIds.includes(t.buildingId || ''));
    const netBorrowing = borrowingTxs.reduce((s, t) => {
      if (t.borrowingType === 'OPENING_BALANCE' && !((t as any).isOwnerOpeningBalance)) {
        return s + (Number(t.amount) || 0);
      } else if (t.borrowingType === 'BORROWED') {
        return s - (Number(t.amount) || 0);
      } else if (t.borrowingType === 'REPAYMENT') {
        return s + (Number(t.amount) || 0);
      }
      return s;
    }, 0);
    return { totalStaffOpeningBalance, netBorrowing, transactions: staffOpeningBalanceTxs };
  }, [transactions, ownerBuildingIds]);

  const ownerMonthlyTrend = useMemo(() => {
    const now = new Date();
    const months: { label: string; income: number; expense: number; profit: number; ownerShare: number }[] = [];
    for (let i = 5; i >= 0; i--) {
      const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const monthKey = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
      const monthLabel = d.toLocaleDateString('en-US', { month: 'short' });
      const monthTxs = transactions.filter(t => t.date && t.date.slice(0, 7) === monthKey && ownerBuildingIds.includes(t.buildingId || ''));
      const income = monthTxs.filter(t => t.type === TransactionType.INCOME).reduce((s, t) => s + (Number(t.amount) || 0), 0);
      const expense = monthTxs.filter(t => t.type === TransactionType.EXPENSE).reduce((s, t) => s + (Number(t.amount) || 0), 0);
      const profit = income - expense;
      months.push({ label: monthLabel, income, expense, profit, ownerShare: profit * sharePercent });
    }
    return months;
  }, [transactions, ownerBuildingIds, sharePercent]);

  /* ═══ end derived data ═══ */
    const reportDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    const periodLabel = dateRange === 'all' ? 'All Time' : dateRange === 'month' ? 'This Month' : dateRange === 'quarter' ? 'This Quarter' : 'This Year';

    const ownerRows = allOwnersSummary.map(o => `
      <tr>
        <td>${o.name}</td>
        <td class="num">${o.sharePercentage}%</td>
        <td class="num green">${o.totalIncome.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num red">${o.totalExpense.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num blue">${o.netProfit.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num blue bold">${o.ownerShare.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num orange">${o.expenses.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num highlight">${o.ownerNetAfterExpense.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        <td class="num violet">${o.openingBalance.toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
      </tr>`).join('');

    const txRows = allOwnersSummary.flatMap(o =>
      o.expenseTxs.map(tx => `
        <tr>
          <td>${o.name}</td>
          <td>${tx.date ? new Date(tx.date).toLocaleDateString('en-US') : '-'}</td>
          <td><span class="badge expense">Expense</span></td>
          <td>${tx.expenseCategory || 'Owner Expense'}</td>
          <td class="truncate">${tx.details || '-'}</td>
          <td class="num red">${Number(tx.amount).toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        </tr>`))
      .join('');

    const obRows = allOwnersSummary.flatMap(o =>
      o.openingBalanceTxs.map(tx => `
        <tr>
          <td>${o.name}</td>
          <td>${tx.date ? new Date(tx.date).toLocaleDateString('en-US') : '-'}</td>
          <td><span class="badge opening">Opening Bal.</span></td>
          <td>Opening Balance</td>
          <td class="truncate">${tx.details || '-'}</td>
          <td class="num violet">${Number(tx.amount).toLocaleString('en-US', {minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        </tr>`))
      .join('');

    const html = `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/>
      <title>Owner Report - ${reportDate}</title>
      <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:Arial,sans-serif;font-size:11px;color:#1e293b;padding:24px}
        h1{font-size:20px;font-weight:900;color:#1e40af;margin-bottom:4px}
        .subtitle{font-size:10px;color:#64748b;margin-bottom:20px}
        h2{font-size:13px;font-weight:800;color:#1e293b;margin:20px 0 8px;padding:6px 10px;background:#f1f5f9;border-radius:6px}
        table{width:100%;border-collapse:collapse;margin-bottom:16px}
        th{background:#1e40af;color:#fff;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:6px 8px;text-align:left}
        th.right{text-align:right}
        td{padding:5px 8px;border-bottom:1px solid #f1f5f9;font-size:10px;vertical-align:middle}
        tr:nth-child(even) td{background:#f8fafc}
        .num{text-align:right;font-family:monospace;font-weight:700}
        .green{color:#16a34a}.red{color:#dc2626}.blue{color:#1e40af}.orange{color:#ea580c}.violet{color:#7c3aed}.highlight{color:#0f766e;background:#f0fdf4 !important}
        .bold{font-weight:900}
        .badge{display:inline-block;padding:2px 6px;border-radius:3px;font-size:8px;font-weight:700;text-transform:uppercase}
        .badge.expense{background:#fee2e2;color:#b91c1c}
        .badge.opening{background:#ede9fe;color:#6d28d9}
        .truncate{max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px}
        .kpi{border:1px solid #e2e8f0;border-radius:6px;padding:10px;text-align:center}
        .kpi-label{font-size:8px;font-weight:700;text-transform:uppercase;color:#64748b;margin-bottom:4px}
        .kpi-val{font-size:15px;font-weight:900}
        tfoot td{font-weight:900;background:#1e40af !important;color:#fff !important;text-align:right}
        tfoot td:first-child{text-align:left}
        @media print{body{padding:12px}}
      </style></head><body>
      <h1>&#9733; Owner Financial Report</h1>
      <p class="subtitle">Generated: ${reportDate} &nbsp;|&nbsp; Period: ${periodLabel} &nbsp;|&nbsp; Admin Report</p>

      <h2>Summary by Owner</h2>
      <table>
        <thead><tr>
          <th>Owner</th><th class="right">Share%</th><th class="right">Income</th><th class="right">Expense</th>
          <th class="right">Net Profit</th><th class="right">Owner Share</th><th class="right">Owner Exp.</th>
          <th class="right">Net After Exp.</th><th class="right">Opening Bal.</th>
        </tr></thead>
        <tbody>${ownerRows}</tbody>
        <tfoot><tr>
          <td>TOTAL</td><td></td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.totalIncome,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.totalExpense,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.netProfit,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.ownerShare,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.expenses,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.ownerNetAfterExpense,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
          <td>${allOwnersSummary.reduce((s,o)=>s+o.openingBalance,0).toLocaleString('en-US',{minimumFractionDigits:0,maximumFractionDigits:0})}</td>
        </tr></tfoot>
      </table>

      ${txRows || obRows ? `<h2>All Owner Transactions (Expenses &amp; Opening Balances)</h2>
      <table>
        <thead><tr>
          <th>Owner</th><th>Date</th><th>Type</th><th>Category</th><th>Details</th><th class="right">Amount (SAR)</th>
        </tr></thead>
        <tbody>${obRows}${txRows}</tbody>
      </table>` : ''}

      <p style="font-size:9px;color:#94a3b8;text-align:center;margin-top:24px">AMLAK PROPERTY MANAGEMENT &bull; CONFIDENTIAL &bull; ${reportDate}</p>
      <script>window.onload=()=>window.print();</script>
    </body></html>`;

    const w = window.open('', '_blank', 'width=1000,height=700');
    if (w) { w.document.write(html); w.document.close(); }
  };

  /* ═══ LOADING ═══ */
  if (loading) {
    return (
      <div className="flex items-center justify-center min-h-[60vh]">
        <div className="text-center">
          <div className="w-10 h-10 mx-auto mb-4 border-2 border-blue-100 border-t-blue-500 rounded-full animate-spin" />
          <p className="text-slate-300 text-xs font-bold tracking-wider uppercase">Loading portfolio...</p>
        </div>
      </div>
    );
  }

  /* ═══ EMPTY STATE ═══ */
  if (owners.length === 0) {
    return (
      <div className="max-w-lg mx-auto mt-20 p-8 text-center">
        <Card className="p-10">
          <div className="w-20 h-20 mx-auto mb-5 rounded-2xl flex items-center justify-center bg-blue-50">
            <Crown size={36} className="text-blue-600" />
          </div>
          <h2 className="text-xl font-black text-slate-700 mb-2">No Owners Found</h2>
          <p className="text-slate-400 text-sm leading-relaxed">
            Go to <strong className="text-slate-600">Employee Management</strong> and add a staff member with the <strong className="text-slate-600">"Owner"</strong> role.
          </p>
        </Card>
      </div>
    );
  }

  /* ═══════════════════════════════════════════════════════════════
     MAIN DASHBOARD RENDER
  ═══════════════════════════════════════════════════════════════ */
  return (
    <div className="max-w-7xl mx-auto px-3 sm:px-6 py-4 sm:py-6 space-y-4 sm:space-y-6">

      {/* ══════════════════════ HERO HEADER ══════════════════════ */}
      <Card style={{ background: 'linear-gradient(145deg, #eff6ff, #f8fafc)' }}>
        <div className="p-4 sm:p-8 relative overflow-hidden">
          {/* Soft decorative circles */}
          <div className="absolute top-0 right-0 w-[250px] h-[250px] rounded-full -translate-y-1/2 translate-x-1/3 pointer-events-none" style={{ background: 'radial-gradient(circle, rgba(30,64,175,0.04) 0%, transparent 70%)' }} />

          <div className="relative z-10">
            <div className="flex flex-col gap-4 sm:gap-5">
              <div className="flex items-center gap-3 sm:gap-4">
                <div className="w-11 h-11 sm:w-14 sm:h-14 rounded-xl sm:rounded-2xl flex items-center justify-center bg-blue-100/60 border border-blue-200/50 flex-shrink-0">
                  <Crown size={20} className="sm:hidden text-blue-600" />
                  <Crown size={24} className="hidden sm:block text-blue-600" />
                </div>
                <div className="min-w-0">
                  <p className="text-[9px] sm:text-[10px] font-bold uppercase tracking-[2px] sm:tracking-[3px] text-blue-500">Investment Portfolio</p>
                  <h1 className="text-lg sm:text-2xl font-black text-slate-800 tracking-tight truncate">
                    {isStandalone ? (selectedOwner?.name || 'Dashboard') : 'Owner Dashboard'}
                  </h1>
                </div>
              </div>

              <div className="flex items-center gap-2 sm:gap-3 flex-wrap">
                {/* Owner Selector — only show when NOT in standalone mode */}
                {!isStandalone && owners.length > 1 && (
                  <div className="relative w-full sm:w-auto">
                    <select value={selectedOwnerId} onChange={e => setSelectedOwnerId(e.target.value)}
                      className="appearance-none w-full sm:w-auto pl-3 sm:pl-4 pr-8 sm:pr-10 py-2 sm:py-2.5 rounded-xl text-xs sm:text-sm font-bold outline-none cursor-pointer bg-white border border-slate-200 text-slate-700 shadow-sm focus:ring-2 focus:ring-blue-100">
                      {owners.map(o => (<option key={o.id} value={o.id}>{o.name} ({o.sharePercentage || 0}%)</option>))}
                    </select>
                  </div>
                )}

                {/* Period Filter */}
                <div className="flex rounded-xl overflow-hidden bg-white border border-slate-100 shadow-sm w-full sm:w-auto">
                  {(['month', 'quarter', 'year', 'all'] as const).map(range => (
                    <button key={range} onClick={() => setDateRange(range)}
                      className={`flex-1 sm:flex-none px-2.5 sm:px-3.5 py-2 text-[9px] sm:text-[10px] font-bold uppercase tracking-wide transition-all duration-200 ${
                        dateRange === range ? 'bg-blue-600 text-white' : 'text-slate-400 hover:text-slate-600 hover:bg-slate-50'
                      }`}>
                      {range === 'all' ? 'All' : range === 'quarter' ? 'Qtr' : range.charAt(0).toUpperCase() + range.slice(1)}
                    </button>
                  ))}
                </div>
              </div>
            </div>

            {/* Owner Info Pills */}
            {selectedOwner && (
              <div className="flex items-center gap-2 sm:gap-3 mt-4 sm:mt-5 flex-wrap">
                {[
                  { icon: Percent, text: `${selectedOwner.sharePercentage || 0}% Share` },
                  { icon: Building2, text: `${ownerBuildings.length} Properties` },
                  { icon: Home, text: `${totals.totalUnits} Units` },
                  ...(selectedOwner.phone ? [{ icon: null as any, text: `📞 ${selectedOwner.phone}` }] : []),
                ].map((pill, i) => (
                  <div key={i} className="flex items-center gap-1.5 px-2.5 sm:px-3 py-1 sm:py-1.5 rounded-lg text-[9px] sm:text-[10px] font-semibold bg-white/80 border border-slate-100 text-slate-500">
                    {pill.icon && <pill.icon size={11} className="text-blue-400" />}
                    {pill.text}
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </Card>

      {/* ══════════════════════ KPI GRID ══════════════════════ */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-2.5 sm:gap-4">
        <KpiCard label="Total Income" value={`${fmt(totals.totalIncome)}`} sub="SAR" icon={TrendingUp} accent="#22c55e" />
        <KpiCard label="Total Expenses" value={`${fmt(totals.totalExpense)}`} sub="SAR" icon={TrendingDown} accent="#ef4444" />
        <KpiCard label="Net Profit" value={`${fmt(totals.totalProfit)}`} sub={`${totals.profitMargin.toFixed(1)}% margin · SAR`} icon={DollarSign} accent="#3b82f6" />
        <KpiCard label="Owner Profit (Net)" value={`${fmt(totals.ownerProfitNet)}`} sub={`${selectedOwner?.sharePercentage || 0}% share minus owner expense · SAR`} icon={Crown} accent={PRIMARY} highlight />
      </div>

      {/* ── Secondary KPIs ── */}
      <div className="grid grid-cols-2 lg:grid-cols-4 gap-2.5 sm:gap-4">
          {[
            { icon: Users, label: 'Occupancy', value: `${totals.occupiedUnits}/${totals.totalUnits}`, sub: `${totals.avgOccupancy.toFixed(0)}%`, accent: '#a855f7' },
            { icon: Wallet, label: 'Monthly Rent', value: `${fmt(totals.expectedMonthlyRent)}`, sub: 'Expected · SAR', accent: '#06b6d4' },
            { icon: Building2, label: 'Properties', value: String(ownerBuildings.length), sub: 'Assigned', accent: '#22c55e' },
            { icon: FileSignature, label: 'Owner Expense', value: `${fmt(totals.ownerExpenseTotal)}`, sub: 'Withdrawn · SAR', accent: '#f97316' },
          ].map((item, i) => (
          <div key={i}><Card className="p-3 sm:p-4 flex items-center gap-2.5 sm:gap-3.5">
            <div className="w-8 h-8 sm:w-10 sm:h-10 rounded-lg sm:rounded-xl flex items-center justify-center flex-shrink-0" style={{ background: `${item.accent}10` }}>
              <item.icon size={15} className="sm:hidden" style={{ color: item.accent }} />
              <item.icon size={17} className="hidden sm:block" style={{ color: item.accent }} />
            </div>
            <div className="min-w-0">
              <p className="text-sm sm:text-lg font-black text-slate-800 leading-none truncate">{item.value}</p>
              <p className="text-[9px] sm:text-[10px] font-semibold mt-0.5 text-slate-400 truncate">{item.label} ({item.sub})</p>
            </div>
          </Card></div>
        ))}
      </div>

      {/* ══════════════════════ PROPERTY TABLE ══════════════════════ */}
      {!isStandalone && currentUser?.role === 'ADMIN' && allOwnersSummary.length > 0 && (
        <Card className="p-4 sm:p-6">
          <div className="flex items-center justify-between gap-2.5 mb-5">
            <div className="flex items-center gap-2.5">
              <div className="w-8 h-8 rounded-lg flex items-center justify-center bg-indigo-100">
                <Users size={15} className="text-indigo-600" />
              </div>
              <h3 className="text-sm font-black text-slate-700 tracking-tight">All Owners — Full Financial Summary (Admin)</h3>
            </div>
            <button
              onClick={handlePrintReport}
              className="flex items-center gap-1.5 px-3 py-2 bg-indigo-600 text-white text-[10px] font-bold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm"
            >
              <Printer size={13} />
              Print PDF Report
            </button>
          </div>
          
          {/* Summary Statistics */}
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-2.5 sm:gap-3 mb-5 pb-5 border-b border-slate-100">
            <div className="bg-emerald-50 border border-emerald-200 rounded-lg p-2.5 sm:p-3 text-center">
              <div className="text-[8px] sm:text-[9px] text-emerald-600 font-bold uppercase tracking-wide mb-1">Total Income</div>
              <div className="text-base sm:text-lg font-black text-emerald-700">{fmt(allOwnersSummary.reduce((s, o) => s + o.totalIncome, 0))}</div>
              <div className="text-[8px] text-slate-400 mt-0.5">SAR</div>
            </div>
            <div className="bg-blue-50 border border-blue-200 rounded-lg p-2.5 sm:p-3 text-center">
              <div className="text-[8px] sm:text-[9px] text-blue-600 font-bold uppercase tracking-wide mb-1">Total Owner Shares</div>
              <div className="text-base sm:text-lg font-black text-blue-700">{fmt(allOwnersSummary.reduce((s, o) => s + o.ownerShare, 0))}</div>
              <div className="text-[8px] text-slate-400 mt-0.5">SAR</div>
            </div>
            <div className="bg-orange-50 border border-orange-200 rounded-lg p-2.5 sm:p-3 text-center">
              <div className="text-[8px] sm:text-[9px] text-orange-600 font-bold uppercase tracking-wide mb-1">Total Withdrawals</div>
              <div className="text-base sm:text-lg font-black text-orange-700">{fmt(allOwnersSummary.reduce((s, o) => s + o.expenses, 0))}</div>
              <div className="text-[8px] text-slate-400 mt-0.5">SAR</div>
            </div>
            <div className="bg-teal-50 border border-teal-200 rounded-lg p-2.5 sm:p-3 text-center">
              <div className="text-[8px] sm:text-[9px] text-teal-600 font-bold uppercase tracking-wide mb-1">Net After Expenses</div>
              <div className="text-base sm:text-lg font-black text-teal-700">{fmt(allOwnersSummary.reduce((s, o) => s + o.ownerNetAfterExpense, 0))}</div>
              <div className="text-[8px] text-slate-400 mt-0.5">SAR · {allOwnersSummary.length} owners</div>
            </div>
          </div>

          {/* Individual Owner Cards */}
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {allOwnersSummary.map((owner) => (
              <div key={owner.id} className="border border-slate-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
                <div className="px-3.5 pt-3.5 pb-2.5 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
                  <h4 className="text-sm font-bold text-slate-800">{owner.name}</h4>
                  <span className="text-[9px] font-bold bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">{owner.sharePercentage}% share</span>
                </div>
                <div className="p-3.5 space-y-2">
                  {[
                    { label: 'Total Income', value: owner.totalIncome, color: 'text-emerald-600' },
                    { label: 'Total Expense', value: owner.totalExpense, color: 'text-red-500' },
                    { label: 'Net Profit', value: owner.netProfit, color: 'text-blue-600' },
                    { label: `Owner Share (${owner.sharePercentage}%)`, value: owner.ownerShare, color: 'text-blue-700' },
                  ].map(row => (
                    <div key={row.label} className="flex items-center justify-between">
                      <span className="text-[10px] text-slate-500 font-semibold">{row.label}</span>
                      <span className={`text-sm font-black tabular-nums ${row.color}`}>{fmt(row.value)}</span>
                    </div>
                  ))}
                  <div className="my-1 border-t border-dashed border-slate-200" />
                  {owner.openingBalance > 0 && (
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-1.5">
                        <div className="w-2 h-2 rounded-full bg-violet-500" />
                        <span className="text-[10px] text-slate-500 font-semibold">Opening Balance</span>
                      </div>
                      <span className="text-sm font-black text-violet-700 tabular-nums">{fmt(owner.openingBalance)}</span>
                    </div>
                  )}
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-1.5">
                      <div className="w-2 h-2 rounded-full bg-orange-500" />
                      <span className="text-[10px] text-slate-500 font-semibold">Owner Expenses</span>
                    </div>
                    <span className="text-sm font-black text-orange-600 tabular-nums">{fmt(owner.expenses)}</span>
                  </div>
                  <div className="flex items-center justify-between pt-2 border-t border-slate-100">
                    <span className="text-[10px] font-bold text-teal-700 uppercase tracking-wide">Net After Expenses</span>
                    <span className={`text-base font-black tabular-nums ${owner.ownerNetAfterExpense >= 0 ? 'text-teal-600' : 'text-red-600'}`}>{fmt(owner.ownerNetAfterExpense)}</span>
                  </div>
                  {/* Owner Expense Transactions */}
                  {owner.expenseTxs.length > 0 && (
                    <details className="mt-1">
                      <summary className="text-[9px] font-bold text-slate-400 uppercase tracking-wide cursor-pointer hover:text-slate-600">View Transactions ({owner.expenseTxs.length})</summary>
                      <div className="mt-2 space-y-1.5">
                        {owner.expenseTxs.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map(tx => (
                          <div key={tx.id} className="flex items-center justify-between bg-orange-50 rounded-lg px-2.5 py-1.5">
                            <div>
                              <span className="text-[9px] font-bold text-orange-700">{tx.expenseCategory || 'Owner Expense'}</span>
                              <p className="text-[9px] text-slate-400">{fmtDate(tx.date)}{tx.details ? ` · ${tx.details}` : ''}</p>
                            </div>
                            <span className="text-xs font-black text-orange-600 tabular-nums">{fmt(Number(tx.amount))}</span>
                          </div>
                        ))}
                      </div>
                    </details>
                  )}
                  {/* Opening Balance Transactions */}
                  {owner.openingBalanceTxs.length > 0 && (
                    <details className="mt-1">
                      <summary className="text-[9px] font-bold text-slate-400 uppercase tracking-wide cursor-pointer hover:text-slate-600">Opening Balance Entries ({owner.openingBalanceTxs.length})</summary>
                      <div className="mt-2 space-y-1.5">
                        {owner.openingBalanceTxs.map(tx => (
                          <div key={tx.id} className="flex items-center justify-between bg-violet-50 rounded-lg px-2.5 py-1.5">
                            <span className="text-[9px] text-slate-400">{fmtDate(tx.date)}</span>
                            <span className="text-xs font-black text-violet-700 tabular-nums">{fmt(Number(tx.amount))}</span>
                          </div>
                        ))}
                      </div>
                    </details>
                  )}
                </div>
              </div>
            ))}
          </div>
        </Card>
      )}

      {/* ══════════════════════ OWNER OPENING BALANCE SECTION ══════════════════════ */}
      {ownerOpeningBalanceData.totalOpeningBalance > 0 && (
        <Card className="p-4 sm:p-5">
          <div className="flex items-center justify-between mb-4">
            <div className="flex items-center gap-2.5">
              <div className="w-8 h-8 rounded-lg flex items-center justify-center bg-amber-100">
                <Wallet size={15} className="text-amber-600" />
              </div>
              <h3 className="text-sm font-black text-slate-700 tracking-tight">Owner Opening Balance (Previous System)</h3>
            </div>
          </div>
          <div className="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
            <div className="bg-amber-50 border border-amber-200 rounded-xl p-3 text-center">
              <div className="text-[10px] text-amber-600 font-bold uppercase tracking-wide mb-1">Opening Balance</div>
              <div className="text-lg font-black text-amber-700">{fmt(ownerOpeningBalanceData.totalOpeningBalance)} <span className="text-xs font-semibold">SAR</span></div>
            </div>
            <div className="bg-emerald-50 border border-emerald-200 rounded-xl p-3 text-center">
              <div className="text-[10px] text-emerald-600 font-bold uppercase tracking-wide mb-1">Paid (Owner Expense)</div>
              <div className="text-lg font-black text-emerald-700">{fmt(totals.ownerExpenseTotal)} <span className="text-xs font-semibold">SAR</span></div>
            </div>
            <div className={`${ownerOpeningBalanceData.outstanding > 0 ? 'bg-rose-50 border-rose-200' : 'bg-slate-50 border-slate-200'} border rounded-xl p-3 text-center`}>
              <div className={`text-[10px] ${ownerOpeningBalanceData.outstanding > 0 ? 'text-rose-600' : 'text-slate-600'} font-bold uppercase tracking-wide mb-1`}>Outstanding</div>
              <div className={`text-lg font-black ${ownerOpeningBalanceData.outstanding > 0 ? 'text-rose-700' : 'text-slate-700'}`}>{fmt(Math.max(0, ownerOpeningBalanceData.outstanding))} <span className="text-xs font-semibold">SAR</span></div>
            </div>
          </div>
          {/* Opening balance entries list - Admin can delete */}
          {currentUser?.role === 'ADMIN' && ownerOpeningBalanceData.transactions.length > 0 && (
            <div className="border-t border-slate-100 pt-3 mt-3">
              <div className="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Opening Balance Entries</div>
              <div className="space-y-2">
                {ownerOpeningBalanceData.transactions.map(tx => (
                  <div key={tx.id} className="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                    <div>
                      <span className="text-sm font-bold text-slate-700">{fmt(tx.amount)} SAR</span>
                      <span className="text-xs text-slate-400 ml-2">{fmtDate(tx.date)}</span>
                    </div>
                    <button
                      onClick={() => handleDeleteOpeningBalance(tx)}
                      className="p-1.5 text-rose-500 hover:text-rose-700 bg-rose-50 rounded-lg hover:bg-rose-100 transition"
                      title="Delete Opening Balance"
                    >
                      <Trash2 size={14} />
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )}
        </Card>
      )}

      {/* ══════════════════════ OWNER OPENING EXPENSE SECTION ══════════════════════ */}
      {ownerOpeningExpenseData.totalOpeningExpense > 0 && (
        <Card className="p-4 sm:p-5">
          <div className="flex items-center justify-between mb-4">
            <div className="flex items-center gap-2.5">
              <div className="w-8 h-8 rounded-lg flex items-center justify-center bg-orange-100">
                <AlertTriangle size={15} className="text-orange-600" />
              </div>
              <h3 className="text-sm font-black text-slate-700 tracking-tight">Owner Opening Expense (Previous System)</h3>
            </div>
          </div>
          <div className="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
            <div className="bg-orange-50 border border-orange-200 rounded-xl p-3 text-center">
              <div className="text-[10px] text-orange-600 font-bold uppercase tracking-wide mb-1">Opening Expense</div>
              <div className="text-lg font-black text-orange-700">{fmt(ownerOpeningExpenseData.totalOpeningExpense)} <span className="text-xs font-semibold">SAR</span></div>
            </div>
          </div>
          {/* Opening expense entries list */}
          {ownerOpeningExpenseData.transactions.length > 0 && (
            <div className="border-t border-slate-100 pt-3 mt-3">
              <div className="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Opening Expense Entries</div>
              <div className="space-y-2">
                {ownerOpeningExpenseData.transactions.map(tx => (
                  <div key={tx.id} className="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                    <div>
                      <span className="text-sm font-bold text-slate-700">{fmt(tx.amount)} SAR</span>
                      <span className="text-xs text-slate-400 ml-2">{fmtDate(tx.date)}</span>
                      <span className="text-xs text-slate-500 ml-2">{tx.details || '-'}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </Card>
      )}

      {/* ══════════════════════ OWNER EXPENSES SECTION ══════════════════════ */}
      {totals.ownerExpenseTotal > 0 && (
        <Card className="p-4 sm:p-5">
          <div className="flex items-center justify-between mb-4">
            <div className="flex items-center gap-2.5">
              <div className="w-8 h-8 rounded-lg flex items-center justify-center bg-orange-100">
                <FileSignature size={15} className="text-orange-600" />
              </div>
              <h3 className="text-sm font-black text-slate-700 tracking-tight">Owner Expenses (Withdrawn)</h3>
            </div>
          </div>
          <div className="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
            <div className="bg-orange-50 border border-orange-200 rounded-xl p-3 text-center">
              <div className="text-[10px] text-orange-600 font-bold uppercase tracking-wide mb-1">Total Expenses</div>
              <div className="text-lg font-black text-orange-700">{fmt(totals.ownerExpenseTotal)} <span className="text-xs font-semibold">SAR</span></div>
            </div>
          </div>
          {/* Owner expense entries list */}
          {ownerScopedTransactions.filter(t => t.type === TransactionType.EXPENSE && OWNER_EXPENSE_CATEGORIES.includes((t.expenseCategory || '') as any)).length > 0 && (
            <div className="border-t border-slate-100 pt-3 mt-3">
              <div className="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Expense Entries</div>
              <div className="space-y-2">
                {ownerScopedTransactions
                  .filter(t => t.type === TransactionType.EXPENSE && OWNER_EXPENSE_CATEGORIES.includes((t.expenseCategory || '') as any))
                  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
                  .map(tx => (
                    <div key={tx.id} className="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                      <div className="flex-1">
                        <div className="flex items-center gap-2">
                          <span className="text-sm font-bold text-slate-700">{fmt(tx.amount)} SAR</span>
                          <span className="text-xs bg-orange-100 text-orange-700 font-bold px-2 py-0.5 rounded">{tx.expenseCategory || 'Owner Expense'}</span>
                        </div>
                        <div className="flex items-center gap-2 mt-1">
                          <span className="text-xs text-slate-400">{fmtDate(tx.date)}</span>
                          <span className="text-xs text-slate-500">{tx.details || '-'}</span>
                        </div>
                      </div>
                    </div>
                  ))}
              </div>
            </div>
          )}
        </Card>
      )}

      {/* ══════════════════════ STAFF BORROWING OPENING BALANCE SECTION ══════════════════════ */}
      <Card className="p-4 sm:p-5">
        <div className="flex items-center justify-between mb-4">
          <div className="flex items-center gap-2.5">
            <div className="w-8 h-8 rounded-lg flex items-center justify-center bg-purple-100">
              <Users size={15} className="text-purple-600" />
            </div>
            <h3 className="text-sm font-black text-slate-700 tracking-tight">Staff Borrowing Opening Balance</h3>
          </div>
        </div>
        <div className="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
          <div className="bg-purple-50 border border-purple-200 rounded-xl p-3 text-center">
            <div className="text-[10px] text-purple-600 font-bold uppercase tracking-wide mb-1">Opening Balance</div>
            <div className="text-lg font-black text-purple-700">{fmt(staffBorrowingOpeningBalance.totalStaffOpeningBalance)} <span className="text-xs font-semibold">SAR</span></div>
          </div>
          <div className={`${staffBorrowingOpeningBalance.netBorrowing > 0 ? 'bg-emerald-50 border-emerald-200' : 'bg-rose-50 border-rose-200'} border rounded-xl p-3 text-center`}>
            <div className={`text-[10px] ${staffBorrowingOpeningBalance.netBorrowing > 0 ? 'text-emerald-600' : 'text-rose-600'} font-bold uppercase tracking-wide mb-1`}>Net Status</div>
            <div className={`text-lg font-black ${staffBorrowingOpeningBalance.netBorrowing > 0 ? 'text-emerald-700' : 'text-rose-700'}`}>
              {staffBorrowingOpeningBalance.netBorrowing > 0 ? '+' : ''}{fmt(staffBorrowingOpeningBalance.netBorrowing)} <span className="text-xs font-semibold">SAR</span>
            </div>
          </div>
        </div>
        {staffBorrowingOpeningBalance.transactions.length > 0 && (
          <div className="border-t border-slate-100 pt-3 mt-3">
            <div className="text-[10px] font-bold text-slate-400 uppercase tracking-wide mb-2">Opening Balance Entries</div>
            <div className="space-y-2">
              {staffBorrowingOpeningBalance.transactions.map(tx => (
                <div key={tx.id} className="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                  <div>
                    <span className="text-sm font-bold text-slate-700">{fmt(tx.amount)} SAR</span>
                    <span className="text-xs text-slate-400 ml-2">{fmtDate(tx.date)}</span>
                    <span className="text-xs text-slate-500 ml-2">Details: {tx.details || '-'}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </Card>

      {/* ══════════════════════ CHARTS ROW ══════════════════════ */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
        {/* Bar Chart */}
        <Card className="p-4 sm:p-6">
          <SectionTitle icon={BarChart3} title="Monthly Performance" accent="#22c55e" />
          <div className="-mx-2 sm:mx-0">
            <ResponsiveContainer width="100%" height={220} className="sm:!h-[280px]">
              <BarChart data={ownerMonthlyTrend} margin={{ top: 5, right: 0, left: -15, bottom: 5 }}>
                <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                <XAxis dataKey="label" tick={{ fontSize: 9, fill: '#94a3b8' }} axisLine={{ stroke: '#e2e8f0' }} tickLine={false} />
                <YAxis tick={{ fontSize: 9, fill: '#94a3b8' }} axisLine={false} tickLine={false} tickFormatter={v => `${(v/1000).toFixed(0)}K`} width={35} />
                <Tooltip content={<ChartTooltip />} />
                <Legend wrapperStyle={{ fontSize: 9 }} />
                <Bar dataKey="income" name="Income" fill="#22c55e" radius={[4, 4, 0, 0]} />
                <Bar dataKey="expense" name="Expense" fill="#ef4444" radius={[4, 4, 0, 0]} />
                <Bar dataKey="ownerShare" name="Owner Share" fill={PRIMARY} radius={[4, 4, 0, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </Card>

        {/* Area Chart */}
        <Card className="p-4 sm:p-6">
          <SectionTitle icon={Activity} title="Revenue Trend" accent="#3b82f6" />
          <div className="-mx-2 sm:mx-0">
            <ResponsiveContainer width="100%" height={220} className="sm:!h-[280px]">
              <AreaChart data={ownerMonthlyTrend} margin={{ top: 5, right: 0, left: -15, bottom: 5 }}>
                <defs>
                  <linearGradient id="ownerIncGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="5%" stopColor="#22c55e" stopOpacity={0.15} /><stop offset="95%" stopColor="#22c55e" stopOpacity={0} /></linearGradient>
                  <linearGradient id="ownerProfGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="5%" stopColor={PRIMARY} stopOpacity={0.15} /><stop offset="95%" stopColor={PRIMARY} stopOpacity={0} /></linearGradient>
                </defs>
                <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                <XAxis dataKey="label" tick={{ fontSize: 9, fill: '#94a3b8' }} axisLine={{ stroke: '#e2e8f0' }} tickLine={false} />
                <YAxis tick={{ fontSize: 9, fill: '#94a3b8' }} axisLine={false} tickLine={false} tickFormatter={v => `${(v/1000).toFixed(0)}K`} width={35} />
                <Tooltip content={<ChartTooltip />} />
                <Legend wrapperStyle={{ fontSize: 9 }} />
                <Area type="monotone" dataKey="income" name="Income" stroke="#22c55e" fill="url(#ownerIncGrad)" strokeWidth={2} />
                <Area type="monotone" dataKey="ownerShare" name="Owner Profit" stroke={PRIMARY} fill="url(#ownerProfGrad)" strokeWidth={2} />
              </AreaChart>
            </ResponsiveContainer>
          </div>
        </Card>
      </div>

      {/* ══════════════════════ PIE CHARTS ══════════════════════ */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-4 sm:gap-6">
        {/* Expense Breakdown */}
        <Card className="p-4 sm:p-6">
          <SectionTitle icon={PieChartIcon} title="Expense Breakdown" accent="#ef4444" />
          {expenseBreakdown.length > 0 ? (
            <div className="flex flex-col items-center gap-4 sm:gap-5">
              <ResponsiveContainer width="100%" height={180} className="sm:!h-[220px]">
                <PieChart>
                  <Pie data={expenseBreakdown} cx="50%" cy="50%" innerRadius={40} outerRadius={70} paddingAngle={3} dataKey="value" strokeWidth={0}>
                    {expenseBreakdown.map((_e, i) => <Cell key={i} fill={CHART_COLORS[i % CHART_COLORS.length]} />)}
                  </Pie>
                  <Tooltip content={<ChartTooltip />} />
                </PieChart>
              </ResponsiveContainer>
              <div className="grid grid-cols-2 sm:flex sm:flex-col gap-2 sm:gap-2.5 w-full sm:min-w-[140px]">
                {expenseBreakdown.slice(0, 6).map((item, i) => (
                  <div key={i} className="flex items-center gap-2 text-[10px] sm:text-[11px]">
                    <div className="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full flex-shrink-0" style={{ background: CHART_COLORS[i % CHART_COLORS.length] }} />
                    <span className="text-slate-400 truncate flex-1">{item.name}</span>
                    <span className="font-bold text-slate-700 tabular-nums">{fmt(item.value)}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : <p className="text-slate-300 text-sm text-center py-10">No expense data</p>}
        </Card>

        {/* Income by Property */}
        <Card className="p-4 sm:p-6">
          <SectionTitle icon={PieChartIcon} title="Income by Property" accent="#22c55e" />
          {incomeBreakdown.length > 0 ? (
            <div className="flex flex-col items-center gap-4 sm:gap-5">
              <ResponsiveContainer width="100%" height={180} className="sm:!h-[220px]">
                <PieChart>
                  <Pie data={incomeBreakdown} cx="50%" cy="50%" innerRadius={40} outerRadius={70} paddingAngle={3} dataKey="value" strokeWidth={0}>
                    {incomeBreakdown.map((_e, i) => <Cell key={i} fill={CHART_COLORS[i % CHART_COLORS.length]} />)}
                  </Pie>
                  <Tooltip content={<ChartTooltip />} />
                </PieChart>
              </ResponsiveContainer>
              <div className="grid grid-cols-2 sm:flex sm:flex-col gap-2 sm:gap-2.5 w-full sm:min-w-[140px]">
                {incomeBreakdown.map((item, i) => (
                  <div key={i} className="flex items-center gap-2 text-[10px] sm:text-[11px]">
                    <div className="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full flex-shrink-0" style={{ background: CHART_COLORS[i % CHART_COLORS.length] }} />
                    <span className="text-slate-400 truncate flex-1">{item.name}</span>
                    <span className="font-bold text-slate-700 tabular-nums">{fmt(item.value)}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : <p className="text-slate-300 text-sm text-center py-10">No income data</p>}
        </Card>
      </div>

      {/* ══════════════════════ PROPERTY TABLE ══════════════════════ */}
      <Card id="ownerPortalPropertyTable">
        <div className="p-4 sm:p-6 border-b border-slate-50">
          <SectionTitle icon={Building2} title="Property Performance" accent="#22c55e" />
        </div>

        {/* Desktop Table */}
        <div className="hidden md:block overflow-x-auto">
          <table className="w-full text-sm">
            <thead>
              <tr className="border-b border-slate-50 bg-slate-50/50">
                {['Property', 'Income', 'Expense', 'Net Profit', "Owner's Share", 'Occupancy', 'Contracts'].map((h, i) => (
                  <th key={h} className={`${i === 0 ? 'text-left' : i <= 4 ? 'text-right' : 'text-center'} px-5 py-3 text-[10px] font-bold uppercase tracking-wider ${i === 4 ? 'text-blue-600 bg-blue-50/50' : 'text-slate-400'}`}>
                    {h}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {buildingFinancials.length > 0 ? buildingFinancials.map((b) => (
                <tr key={b.id} className="border-b border-slate-50 hover:bg-blue-50/30 transition-colors">
                  <td className="px-5 py-4">
                    <div className="flex items-center gap-2.5">
                      <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 bg-emerald-50">
                        <Building2 size={13} className="text-emerald-500" />
                      </div>
                      <span className="font-bold text-slate-700 text-xs">{b.name}</span>
                    </div>
                  </td>
                  <td className="text-right px-5 py-4 font-mono font-bold text-emerald-600 text-xs tabular-nums">{fmt(b.income)}</td>
                  <td className="text-right px-5 py-4 font-mono font-bold text-red-500 text-xs tabular-nums">{fmt(b.expense)}</td>
                  <td className={`text-right px-5 py-4 font-mono font-bold text-xs tabular-nums ${b.profit >= 0 ? 'text-blue-600' : 'text-red-500'}`}>{b.profit >= 0 ? '+' : ''}{fmt(b.profit)}</td>
                  <td className="text-right px-5 py-4 font-mono font-black text-blue-700 text-xs tabular-nums bg-blue-50/30">{fmt(b.ownerShare)}</td>
                  <td className="text-center px-5 py-4">
                    <div className="flex items-center justify-center gap-2">
                      <div className="w-14 h-1.5 rounded-full overflow-hidden bg-slate-100">
                        <div className="h-full rounded-full transition-all duration-500" style={{ width: `${Math.min(b.occupancyRate, 100)}%`, background: b.occupancyRate >= 80 ? '#22c55e' : b.occupancyRate >= 50 ? '#f59e0b' : '#ef4444' }} />
                      </div>
                      <span className="text-[10px] font-bold text-slate-400 tabular-nums">{b.occupancyRate.toFixed(0)}%</span>
                    </div>
                  </td>
                  <td className="text-center px-5 py-4 font-bold text-slate-500 text-xs">{b.activeContracts}</td>
                </tr>
              )) : <tr><td colSpan={7} className="text-center py-10 text-slate-300 text-xs">No properties assigned</td></tr>}
              {buildingFinancials.length > 0 && (
                <tr className="border-t-2 border-slate-100 bg-slate-50/30">
                  <td className="px-5 py-3.5 font-black text-slate-600 text-xs uppercase tracking-wider">Total</td>
                  <td className="text-right px-5 py-3.5 font-mono font-black text-emerald-600 text-xs">{fmt(totals.totalIncome)}</td>
                  <td className="text-right px-5 py-3.5 font-mono font-black text-red-500 text-xs">{fmt(totals.totalExpense)}</td>
                  <td className="text-right px-5 py-3.5 font-mono font-black text-blue-600 text-xs">{fmt(totals.totalProfit)}</td>
                  <td className="text-right px-5 py-3.5 font-mono font-black text-blue-700 text-xs bg-blue-50/30">{fmt(totals.ownerProfit)}</td>
                  <td className="text-center px-5 py-3.5 font-bold text-slate-500 text-xs">{totals.avgOccupancy.toFixed(0)}%</td>
                  <td className="text-center px-5 py-3.5 font-bold text-slate-500 text-xs">{contracts.filter(c => ownerBuildingIds.includes(c.buildingId) && c.status === 'Active').length}</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>

        {/* Mobile Card Layout */}
        <div className="md:hidden p-3 space-y-3">
          {buildingFinancials.length > 0 ? buildingFinancials.map((b) => (
            <div key={b.id} className="rounded-xl border border-slate-100 bg-slate-50/30 overflow-hidden">
              {/* Property Header */}
              <div className="flex items-center gap-2.5 p-3 bg-white border-b border-slate-100">
                <div className="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 bg-emerald-50">
                  <Building2 size={13} className="text-emerald-500" />
                </div>
                <span className="font-bold text-slate-700 text-sm flex-1 truncate">{b.name}</span>
                <span className="text-[9px] font-bold text-slate-400">{b.activeContracts} contracts</span>
              </div>
              {/* Financials Grid */}
              <div className="grid grid-cols-2 gap-px bg-slate-100">
                <div className="bg-white p-3">
                  <p className="text-[9px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Income</p>
                  <p className="font-mono font-bold text-emerald-600 text-sm tabular-nums">{fmt(b.income)}</p>
                </div>
                <div className="bg-white p-3">
                  <p className="text-[9px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Expense</p>
                  <p className="font-mono font-bold text-red-500 text-sm tabular-nums">{fmt(b.expense)}</p>
                </div>
                <div className="bg-white p-3">
                  <p className="text-[9px] font-bold uppercase tracking-wider text-slate-400 mb-0.5">Net Profit</p>
                  <p className={`font-mono font-bold text-sm tabular-nums ${b.profit >= 0 ? 'text-blue-600' : 'text-red-500'}`}>{b.profit >= 0 ? '+' : ''}{fmt(b.profit)}</p>
                </div>
                <div className="bg-blue-50/50 p-3">
                  <p className="text-[9px] font-bold uppercase tracking-wider text-blue-500 mb-0.5">Owner Share</p>
                  <p className="font-mono font-black text-blue-700 text-sm tabular-nums">{fmt(b.ownerShare)}</p>
                </div>
              </div>
              {/* Occupancy Bar */}
              <div className="flex items-center gap-2.5 p-3 bg-white">
                <span className="text-[9px] font-bold uppercase text-slate-400">Occupancy</span>
                <div className="flex-1 h-1.5 rounded-full overflow-hidden bg-slate-100">
                  <div className="h-full rounded-full transition-all duration-500" style={{ width: `${Math.min(b.occupancyRate, 100)}%`, background: b.occupancyRate >= 80 ? '#22c55e' : b.occupancyRate >= 50 ? '#f59e0b' : '#ef4444' }} />
                </div>
                <span className="text-[10px] font-bold text-slate-500 tabular-nums">{b.occupancyRate.toFixed(0)}%</span>
              </div>
            </div>
          )) : (
            <p className="text-center py-10 text-slate-300 text-xs">No properties assigned</p>
          )}
          {/* Mobile Total Summary */}
          {buildingFinancials.length > 0 && (
            <div className="rounded-xl border-2 border-blue-100 bg-blue-50/30 p-3">
              <p className="text-[10px] font-black uppercase tracking-wider text-blue-600 mb-2">Portfolio Total</p>
              <div className="grid grid-cols-2 gap-2">
                <div><p className="text-[9px] text-slate-400 font-bold">Income</p><p className="font-mono font-black text-emerald-600 text-sm">{fmt(totals.totalIncome)}</p></div>
                <div><p className="text-[9px] text-slate-400 font-bold">Expense</p><p className="font-mono font-black text-red-500 text-sm">{fmt(totals.totalExpense)}</p></div>
                <div><p className="text-[9px] text-slate-400 font-bold">Net Profit</p><p className="font-mono font-black text-blue-600 text-sm">{fmt(totals.totalProfit)}</p></div>
                <div><p className="text-[9px] text-blue-500 font-bold">Owner Share</p><p className="font-mono font-black text-blue-700 text-sm">{fmt(totals.ownerProfit)}</p></div>
              </div>
            </div>
          )}
        </div>
      </Card>

      {/* ══════════════════════ RECENT TRANSACTIONS ══════════════════════ */}
      <Card>
        <div className="p-4 sm:p-6 flex items-center justify-between border-b border-slate-50">
          <SectionTitle icon={Activity} title="Recent Transactions" accent="#a855f7" />
          <span className="text-[10px] font-semibold text-slate-300">Last 10</span>
        </div>

        {/* Desktop Table */}
        <div className="hidden md:block overflow-x-auto">
          <table className="w-full text-sm">
            <thead>
              <tr className="border-b border-slate-50 bg-slate-50/50">
                {['Date', 'Type', 'Details', 'Building', 'Amount (SAR)'].map((h, i) => (
                  <th key={h} className={`${i <= 3 ? 'text-left' : 'text-right'} px-5 py-3 text-[10px] font-bold uppercase tracking-wider text-slate-400`}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {recentTransactions.length > 0 ? recentTransactions.map(tx => (
                <tr key={tx.id} className="border-b border-slate-50 hover:bg-slate-50/50 transition-colors">
                  <td className="px-5 py-3.5 text-slate-500 text-xs font-medium">{fmtDate(tx.date)}</td>
                  <td className="px-5 py-3.5">
                    <span className={`inline-flex items-center gap-1 text-[10px] font-bold px-2.5 py-1 rounded-lg ${
                      tx.type === TransactionType.INCOME ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-500'
                    }`}>
                      {tx.type === TransactionType.INCOME ? <ArrowUpRight size={10} /> : <ArrowDownRight size={10} />}
                      {tx.type}
                    </span>
                  </td>
                  <td className="px-5 py-3.5 text-slate-500 text-xs max-w-[200px] truncate">{tx.details}</td>
                  <td className="px-5 py-3.5 text-slate-400 text-[10px]">{tx.buildingName || buildings.find(b => b.id === tx.buildingId)?.name || '—'}</td>
                  <td className={`px-5 py-3.5 text-right font-mono font-bold text-xs tabular-nums ${
                    tx.type === TransactionType.INCOME ? 'text-emerald-600' : 'text-red-500'
                  }`}>
                    {tx.type === TransactionType.INCOME ? '+' : '-'}{fmt(Number(tx.amount) || 0)}
                  </td>
                </tr>
              )) : <tr><td colSpan={5} className="text-center py-10 text-slate-300 text-xs">No transactions found</td></tr>}
            </tbody>
          </table>
        </div>

        {/* Mobile Card Layout */}
        <div className="md:hidden p-3 space-y-2">
          {recentTransactions.length > 0 ? recentTransactions.map(tx => (
            <div key={tx.id} className="flex items-center gap-3 p-3 rounded-xl bg-slate-50/50 border border-slate-100">
              <div className={`w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 ${
                tx.type === TransactionType.INCOME ? 'bg-emerald-50' : 'bg-red-50'
              }`}>
                {tx.type === TransactionType.INCOME ? <ArrowUpRight size={15} className="text-emerald-500" /> : <ArrowDownRight size={15} className="text-red-400" />}
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-xs font-bold text-slate-700 truncate">{tx.details || tx.type}</p>
                <div className="flex items-center gap-2 mt-0.5">
                  <span className="text-[9px] font-medium text-slate-400">{fmtDate(tx.date)}</span>
                  <span className="text-[9px] text-slate-300">•</span>
                  <span className="text-[9px] font-medium text-slate-400 truncate">{tx.buildingName || buildings.find(b => b.id === tx.buildingId)?.name || '—'}</span>
                </div>
              </div>
              <p className={`font-mono font-bold text-sm tabular-nums flex-shrink-0 ${
                tx.type === TransactionType.INCOME ? 'text-emerald-600' : 'text-red-500'
              }`}>
                {tx.type === TransactionType.INCOME ? '+' : '-'}{fmt(Number(tx.amount) || 0)}
              </p>
            </div>
          )) : (
            <p className="text-center py-10 text-slate-300 text-xs">No transactions found</p>
          )}
        </div>
      </Card>

      {/* ══════════════════════ PROFIT DISTRIBUTION SUMMARY ══════════════════════ */}
      <Card style={{ background: 'linear-gradient(145deg, #eff6ff, #f8fafc)', border: '1px solid rgba(30,64,175,0.08)' }}>
        <div className="p-4 sm:p-8">
          <div className="flex items-center gap-3 sm:gap-3.5 mb-4 sm:mb-6">
            <div className="w-10 h-10 sm:w-12 sm:h-12 rounded-xl sm:rounded-2xl flex items-center justify-center bg-blue-100/60 border border-blue-200/50 flex-shrink-0">
              <Sparkles size={18} className="sm:hidden text-blue-600" />
              <Sparkles size={20} className="hidden sm:block text-blue-600" />
            </div>
            <div>
              <h3 className="text-sm sm:text-base font-black text-slate-800 tracking-tight">Profit Distribution</h3>
              <p className="text-[9px] sm:text-[10px] font-semibold text-blue-500">Based on {selectedOwner?.sharePercentage || 0}% ownership</p>
            </div>
          </div>

          <div className="grid grid-cols-2 md:grid-cols-4 gap-2.5 sm:gap-4">
            {[
              { label: 'Total Net Profit', value: fmt(totals.totalProfit), color: '#1e293b' },
              { label: `Owner Share (${selectedOwner?.sharePercentage || 0}%)`, value: fmt(totals.ownerProfit), color: PRIMARY },
              { label: 'Owner Expense', value: fmt(totals.ownerExpenseTotal), color: '#ef4444' },
              { label: 'Owner Net After Expense', value: fmt(totals.ownerProfitNet), color: '#22c55e' },
            ].map((item, i) => (
              <div key={i} className="bg-white rounded-xl p-3 sm:p-4 border border-slate-100 shadow-sm">
                <p className="text-[8px] sm:text-[10px] font-bold uppercase tracking-wider mb-1 sm:mb-2 text-slate-400 leading-tight">{item.label}</p>
                <p className="text-base sm:text-xl font-black tabular-nums" style={{ color: item.color }}>{item.value}</p>
                <p className="text-[9px] sm:text-[10px] mt-0.5 font-semibold text-slate-300">SAR</p>
              </div>
            ))}
          </div>
        </div>
      </Card>

      {/* ══════════════════════ DELETE OPENING BALANCE CONFIRMATION MODAL ══════════════════════ */}
      {showDeleteOBConfirm && deletingOBTx && (
        <div className="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4" onClick={() => setShowDeleteOBConfirm(false)}>
          <div className="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden" onClick={e => e.stopPropagation()}>
            <div className="bg-gradient-to-r from-rose-600 to-rose-500 text-white p-5 flex justify-between items-center">
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
                  <Trash2 size={20} />
                </div>
                <div>
                  <h3 className="font-bold text-base">Delete Opening Balance</h3>
                  <p className="text-rose-200 text-xs mt-0.5">This action cannot be undone</p>
                </div>
              </div>
              <button onClick={() => setShowDeleteOBConfirm(false)} className="p-1 hover:bg-white/10 rounded-lg transition-all">
                <X size={18} />
              </button>
            </div>
            <div className="p-5">
              <div className="bg-rose-50 border border-rose-200 rounded-xl p-4 mb-4">
                <div className="flex items-center gap-2 text-rose-700 font-bold text-sm mb-2">
                  <AlertTriangle size={16} />
                  <span>Are you sure?</span>
                </div>
                <p className="text-xs text-rose-600">
                  Delete opening balance of <span className="font-bold">{deletingOBTx.amount.toLocaleString()} SAR</span> for {selectedOwner?.name || 'Owner'}?
                </p>
              </div>
              <div className="flex gap-3">
                <button
                  onClick={() => setShowDeleteOBConfirm(false)}
                  className="flex-1 py-3 bg-slate-100 text-slate-700 rounded-xl text-sm font-bold hover:bg-slate-200 transition-all"
                >
                  Cancel
                </button>
                <button
                  onClick={confirmDeleteOpeningBalance}
                  disabled={deleteOBLoading}
                  className="flex-1 py-3 bg-rose-500 text-white rounded-xl text-sm font-bold hover:bg-rose-600 shadow-lg shadow-rose-200 transition-all flex items-center justify-center gap-2 disabled:opacity-60"
                >
                  {deleteOBLoading ? (
                    <div className="animate-spin rounded-full h-4 w-4 border-2 border-white/30 border-t-white" />
                  ) : (
                    <Trash2 size={16} />
                  )}
                  Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ── Footer ── */}
      <div className="text-center pb-4">
        <p className="text-[9px] font-bold uppercase tracking-[4px] text-slate-200">AMLAK PREMIUM  •  OWNER PORTAL</p>
      </div>
    </div>
  );
};

export default OwnerPortal;
